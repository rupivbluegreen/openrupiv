{
  "specVersion": "0.1",
  "app": {
    "name": "Project Tracker",
    "slug": "project-tracker",
    "version": "0.1.0",
    "roles": [
      "member",
      "lead"
    ]
  },
  "entities": [
    {
      "name": "Project",
      "fields": [
        {
          "name": "name",
          "type": "string",
          "required": true,
          "unique": true
        },
        {
          "name": "budget",
          "type": "number"
        },
        {
          "name": "dueDate",
          "type": "date"
        },
        {
          "name": "phase",
          "type": "enum",
          "required": true,
          "values": [
