================ app/test/spec.test.mjs ================
// Invariant tests for the "notes" app directory.
// Generated by @openrupiv/compiler. Runs standalone with plain Node >= 20:
//
//   node --test
//
// Zero dependencies by design: node:test and node:assert only. The app
// directory is declarative data (ADR-0004); these tests check its internal
// consistency without any platform code.
import { test } from "node:test";
import assert from "node:assert/strict";
import { readFileSync } from "node:fs";

const rawSpec = readFileSync(new URL("../spec.json", import.meta.url), "utf8");
const migration = readFileSync(
  new URL("../migrations/0001_init.sql", import.meta.url),
  "utf8",
);

let spec = null;
let specParseError = null;
try {
  spec = JSON.parse(rawSpec);
} catch (error) {
  specParseError = error;
}

function requireSpec() {
  assert.equal(
    specParseError,
    null,
    "spec.json must parse as JSON: " + specParseError,
  );
  assert.ok(
    spec !== null && typeof spec === "object" && !Array.isArray(spec),
    "spec.json must be a JSON object",
  );
  return spec;
}

// Must mirror the compiler's SQL naming convention exactly:
// PascalCase/camelCase -> snake_case.
function snakeCase(name) {
  return name
    .replace(/([A-Z]+)([A-Z][a-z])/g, "$1_$2")
    .replace(/([a-z0-9])([A-Z])/g, "$1_$2")
    .toLowerCase();
}

test("spec.json parses as a JSON object", () => {
  requireSpec();
});

test("specVersion is 0.1", () => {
  assert.equal(requireSpec().specVersion, "0.1");
});

test("every workflow state exists on its entity's state field", () => {
  const s = requireSpec();
  for (const workflow of s.workflows ?? []) {
    const entity = (s.entities ?? []).find(
      (candidate) => candidate.name === workflow.entity,
    );
    assert.ok(
      entity,
      "workflow " + workflow.name + " names missing entity " + workflow.entity,
    );
    const stateField = (entity.fields ?? []).find(
      (field) => field.name === workflow.stateField,
    );
    assert.ok(
      stateField,
      "workflow " + workflow.name + " names missing state field " + workflow.stateField,
    );
    assert.equal(
      stateField.type,
      "enum",
      "state field " + workflow.stateField + " must be an enum",
    );
    const states = new Set(stateField.values ?? []);
    assert.ok(
      states.has(workflow.initial),
      "initial state " + workflow.initial + " is not a declared state",
    );
    for (const transition of workflow.transitions ?? []) {
      assert.ok(
        states.has(transition.from),
        "transition " + transition.name + " from-state " + transition.from + " is not a declared state",
      );
      assert.ok(
        states.has(transition.to),
        "transition " + transition.name + " to-state " + transition.to + " is not a declared state",
      );
    }
  }
});

test("every approval transition requires at least 2 distinct approvers", () => {
  const s = requireSpec();
  for (const workflow of s.workflows ?? []) {
    for (const transition of workflow.transitions ?? []) {
      if (transition.approval === undefined) continue;
      assert.ok(
        Number.isInteger(transition.approval.count) && transition.approval.count >= 2,
        "approval on transition " + transition.name + " must require >= 2 distinct approvers, got " + transition.approval.count,
      );
    }
  }
});

test("the migration creates every table the spec requires", () => {
  const s = requireSpec();
  const tables = [];
  for (const entity of s.entities ?? []) {
    tables.push(snakeCase(entity.name));
    for (const relation of entity.relations ?? []) {
      tables.push(snakeCase(entity.name) + "_" + snakeCase(relation.name));
    }
  }
  assert.ok(tables.length > 0, "spec must declare at least one entity");
  for (const table of tables) {
    assert.ok(
      migration.includes("CREATE TABLE " + table + " ("),
      "migration must create table " + table,
    );
  }
});

test("the migration enables pgcrypto before using gen_random_uuid()", () => {
  assert.ok(
    migration.startsWith("CREATE EXTENSION IF NOT EXISTS pgcrypto;"),
    "migration must start with the pgcrypto extension",
  );
});
"
`;

exports[`compileApp — full output snapshots > projectTrackerSpec 1`] = `
"================ app/README.md ================
# Project Tracker

Generated by \`@openrupiv/compiler\` from [\`spec.json\`](./spec.json). Do not
edit these files by hand — edit the spec and recompile; the same spec always
produces byte-identical output (ADR-0001).

| | |
|---|---|
| Slug | \`project-tracker\` |
| App version | \`0.1.0\` |
| Spec version | \`0.1\` |
| Roles | \`member\`, \`lead\` |

## Contents

| File | Purpose |
|---|---|
| \`spec.json\` | Canonical app spec — the contract |
| \`migrations/0001_init.sql\` | Database schema (versioned, forward-only) |
| \`package.json\`, \`test/\` | Standalone invariant tests — \`node --test\`, zero dependencies |
| \`server.mjs\` | Optional entry: serve this directory with \`@openrupiv/runtime\` |

## Entities

### Project

SQL table: \`project\` · API base path: \`/api/project\`

| Field | Type | Column | SQL type | Constraints | Default |
|---|---|---|---|---|---|
| \`name\` | string | \`name\` | \`text\` | required, unique | — |
| \`budget\` | number | \`budget\` | \`double precision\` | — | — |
| \`dueDate\` | date | \`due_date\` | \`date\` | — | — |
| \`phase\` | enum(planned, active, done) | \`phase\` | \`text\` | required | \`"planned"\` |

Relations:

| Relation | Kind | Target | Join table |
|---|---|---|---|
| \`tags\` | manyToMany | Tag | \`project_tags\` |

### Tag

SQL table: \`tag\` · API base path: \`/api/tag\`

| Field | Type | Column | SQL type | Constraints | Default |
|---|---|---|---|---|---|
| \`label\` | string | \`label\` | \`text\` | required, unique | — |

Every entity table also carries \`id uuid\` (primary key), \`created_at\`, and
\`updated_at\` — set by the database, never by clients.

## Workflows

### \`project-lifecycle\` — Project.phase

State machine on \`Project.phase\`; initial state \`planned\`.
The \`phase\` field is read-only through the create/update API:
the server sets the initial value on create, and the transitions below are
the only writer.

\`\`\`
[*] --> planned
planned --kick-off--> active   [roles: lead] [budget > 0]
active --complete--> done   [dueDate is set]
\`\`\`

| Transition | From | To | Guard roles | Guard predicates | Approvals required |
|---|---|---|---|---|---|
| \`kick-off\` | \`planned\` | \`active\` | \`lead\` | budget > 0 | — |
| \`complete\` | \`active\` | \`done\` | — | dueDate is set | — |

## Pages

| Page | Route | Type | Entity | Title | Fields |
|---|---|---|---|---|---|
| \`projects\` | \`/p/projects\` | list | Project | projects | all fields |
| \`project-form\` | \`/p/project-form\` | form | Project | project-form | all fields |
| \`tags\` | \`/p/tags\` | list | Tag | tags | all fields |

## HTTP routes

Served by \`@openrupiv/runtime\`. Every route requires an authenticated OIDC
session except \`/healthz\`, \`/auth/login\`, and \`/auth/callback\`. There is no
DELETE in v0. Workflow state fields cannot be written through create/update.

| Method | Path | Purpose |
|---|---|---|
| GET | \`/healthz\` | Liveness probe (no auth) |
| GET | \`/auth/login\` | Start OIDC login (Authorization Code + PKCE) |
| GET | \`/auth/callback\` | OIDC redirect target; establishes the session |
| POST | \`/auth/logout\` | Destroy the session |
| GET | \`/\` | Index of pages |
| GET | \`/api/project\` | List Project records |
| POST | \`/api/project\` | Create a Project |
| GET | \`/api/project/:id\` | Fetch one Project |
| PUT | \`/api/project/:id\` | Update a Project |
| GET | \`/api/tag\` | List Tag records |
| POST | \`/api/tag\` | Create a Tag |
| GET | \`/api/tag/:id\` | Fetch one Tag |
| PUT | \`/api/tag/:id\` | Update a Tag |
| POST | \`/api/project/:id/transitions/kick-off\` | Fire \`kick-off\` (planned → active) |
| POST | \`/api/project/:id/transitions/complete\` | Fire \`complete\` (active → done) |
| GET | \`/p/projects\` | Page \`projects\` (list of Project) |
| GET | \`/p/project-form\` | Page \`project-form\` (form of Project) |
| GET | \`/p/tags\` | Page \`tags\` (list of Tag) |

Transition endpoints respond \`{ "status": "pending", "approvals": k, "required": n }\`
while approvals are outstanding and \`{ "status": "transitioned", "state": "<to>" }\` on
completion. Failures: 403 \`ERR_FORBIDDEN_ROLE\`; 409 \`ERR_BAD_STATE\`,
\`ERR_GUARD_FAILED\`, or \`ERR_DUPLICATE_APPROVER\` (the same user may not
approve twice — approvals must come from distinct authenticated users).

## Running this app

- **Tests** (zero installs, Node ≥ 20): \`node --test\`
- **Serve with the runtime library:** install \`@openrupiv/runtime\`, then
  \`node server.mjs\`. Configuration comes from the environment:
  \`DATABASE_URL\`, \`OIDC_ISSUER\`, \`OIDC_CLIENT_ID\`, \`OIDC_CLIENT_SECRET\`,
  \`SESSION_SECRET\`, \`BASE_URL\`. Authentication is OIDC only — there is no
  local-password mode (ADR-0003).
- **Or via the workspace Compose stack:** \`docker compose up\` from the
  workspace root (bundles Postgres and a dev-only Dex IdP, ADR-0002).

================ app/migrations/0001_init.sql ================
CREATE EXTENSION IF NOT EXISTS pgcrypto;

-- Migration 0001_init for app "project-tracker" v0.1.0 (spec v0.1).
-- Generated by @openrupiv/compiler as a deterministic projection of app/spec.json.
-- Forward-only: never edit a migration after it has been applied; add a new one.

CREATE TABLE project (
  id uuid PRIMARY KEY DEFAULT gen_random_uuid(),
  name text NOT NULL UNIQUE,
  budget double precision,
  due_date date,
  phase text NOT NULL DEFAULT 'planned' CHECK (phase IN ('planned', 'active', 'done')),
  created_at timestamptz NOT NULL DEFAULT now(),
  updated_at timestamptz NOT NULL DEFAULT now()
);

CREATE TABLE tag (
  id uuid PRIMARY KEY DEFAULT gen_random_uuid(),
  label text NOT NULL UNIQUE,
  created_at timestamptz NOT NULL DEFAULT now(),
  updated_at timestamptz NOT NULL DEFAULT now()
);

CREATE TABLE project_tags (
  project_id uuid NOT NULL REFERENCES project(id),
  tag_id uuid NOT NULL REFERENCES tag(id),
  PRIMARY KEY (project_id, tag_id)
);

