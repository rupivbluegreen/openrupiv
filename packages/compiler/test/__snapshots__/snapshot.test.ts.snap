          "from": "planned",
          "to": "active",
          "guard": {
            "roles": [
              "lead"
            ],
            "require": [
              {
                "field": "budget",
                "op": "gt",
                "value": 0
              }
            ]
          }
        },
        {
          "name": "complete",
          "from": "active",
          "to": "done",
          "guard": {
            "require": [
