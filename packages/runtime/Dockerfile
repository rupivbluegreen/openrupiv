# @openrupiv/runtime image.
#
# IMPORTANT: the build context is the MONOREPO ROOT (the runtime consumes the
# @openrupiv/spec workspace package). Build with:
#
#   docker build -f packages/runtime/Dockerfile -t openrupiv-runtime .
#
# The Compose stack generated by `openrupiv new` builds this image and runs it
# with APP_DIR pointing at the mounted app directory:
#
#   runtime:
#     build:
#       context: <monorepo root>
#       dockerfile: packages/runtime/Dockerfile
#     environment:
#       APP_DIR: /app-dir
#       DATABASE_URL: postgres://...
#       OIDC_ISSUER: http://dex:5556
#       ...
#     volumes:
#       - ./app:/app-dir:ro

FROM node:22-alpine

ENV COREPACK_ENABLE_DOWNLOAD_PROMPT=0 \
    NODE_ENV=production

RUN corepack enable

WORKDIR /workspace

# Install as root for cache/permission simplicity. Workspace manifests first
# for layer caching, then the packages. The runtime runs from TypeScript
# source via tsx in v0, so dev dependencies are installed (--prod=false) —
# tsx and typescript live in the root devDependencies. A .dockerignore at the
# build-context root keeps host node_modules/.env/.git out of the image.
COPY package.json pnpm-lock.yaml pnpm-workspace.yaml tsconfig.base.json ./
COPY packages ./packages

RUN corepack pnpm install --frozen-lockfile --prod=false \
  && chown -R node:node /workspace

# Drop privileges: the web server runs as the unprivileged built-in `node`
# user (uid 1000), never root. The mounted APP_DIR is read-only and
# world-readable, so no ownership change is needed there.
USER node

EXPOSE 3000

HEALTHCHECK --interval=10s --timeout=3s --retries=12 \
  CMD wget -qO- "http://127.0.0.1:${PORT:-3000}/healthz" >/dev/null 2>&1 || exit 1

# APP_DIR must be provided (bin/serve.mjs exits with a typed error otherwise).
CMD ["corepack", "pnpm", "--filter", "@openrupiv/runtime", "exec", "tsx", "bin/serve.mjs"]
